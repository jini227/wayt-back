PORT=19191
WAYT_PUBLIC_BASE_URL=http://localhost:19191

# Local test uses H2 by default. Leave these empty unless connecting a real DB.
WAYT_DATASOURCE_URL=jdbc:h2:mem:wayt;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH
WAYT_DATASOURCE_USERNAME=sa
WAYT_DATASOURCE_PASSWORD=
WAYT_DATASOURCE_DRIVER=org.h2.Driver
WAYT_FLYWAY_ENABLED=false
WAYT_JPA_DDL_AUTO=create-drop
WAYT_H2_CONSOLE_ENABLED=true

# Required when real Kakao login is wired.
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:19191/api/auth/kakao/callback
# Optional. Enable only after these consent items are configured in Kakao Developers.
KAKAO_SCOPES=

# Required when Naver Maps / geocoding / directions are wired.
NAVER_MAPS_NCP_KEY_ID=
NAVER_MAPS_NCP_KEY=

# Optional. Enables richer POI search such as stations, airports, and shops.
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
